{
  "name": "sleeve",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "security:scan": "./scripts/check-secrets.sh",
    "verify": "pnpm security:scan && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1085.0",
    "@aws-sdk/client-s3": "3.1085.0",
    "@aws-sdk/client-sts": "3.1085.0",
    "@aws-sdk/credential-providers": "3.1085.0",
    "@aws-sdk/lib-dynamodb": "3.1085.0",
    "@aws-sdk/s3-request-presigner": "3.1085.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "6.17.2",
    "server-only": "^0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "typescript": "^5.9.3",
    "vitest": "4.1.10"
  }
}
