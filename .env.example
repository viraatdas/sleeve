# Public application configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
SLEEVE_FROM_EMAIL=Sleeve <sleeve@example.com>

# Generate with: openssl rand -base64 32
AUTH_SECRET=
DATA_ENCRYPTION_KEY=
CRON_SECRET=

# Email delivery
RESEND_API_KEY=

# AWS resources (prefer Vercel OIDC in deployed environments)
AWS_REGION=us-west-2
AWS_ROLE_ARN=
SLEEVE_TABLE_NAME=sleeve-production
SLEEVE_BUCKET_NAME=
SLEEVE_KMS_KEY_ARN=

# Local bootstrap only; never use NEXT_PUBLIC_ prefixes for these
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Modal extraction endpoint
MODAL_EXTRACT_URL=
MODAL_SHARED_SECRET=

# Local visual development only; ignored outside NODE_ENV=development
SLEEVE_LOCAL_DEMO=0
